<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.foodtime.mapper.OrderDetailMapper">

    <insert id="insertBatch">
        insert into
        order_detail(
                     name,
                     image,
                     dish_id,
                     setmeal_id,
                     dish_flavor,
                     number,
                     amount,
                     order_id
        )
        values
            <foreach collection="orderDetailsList" item="od" separator=",">
                (#{od.name},
                 #{od.image},
                 #{od.dishId},
                 #{od.setmealId},
                 #{od.dishFlavor},
                 #{od.number},
                 #{od.amount},
                 #{od.orderId})
            </foreach>
    </insert>
</mapper>